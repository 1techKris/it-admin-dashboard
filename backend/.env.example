APP_NAME=it-admin-dashboard
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# DB: using SQLite by default for quick start (switch to Postgres later)
DB_URL=sqlite+aiosqlite:///./admindb.sqlite3

# Teams webhook (leave empty until configured)
TEAMS_WEBHOOK_URL=

# Auth placeholders
JWT_SECRET=change-me
JWT_ALG=HS256
